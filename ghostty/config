# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

#=================== PeterWYR's Ghostty config=====================
# Basic Config
window-padding-x = 12,4
window-padding-y = 12,4
theme = Rose Pine
font-family = "IosevkaTerm Nerd Font Mono"
font-size = 22
font-thicken = false
font-style-italic = false
font-style-bold-italic = false
quit-after-last-window-closed = true
background-opacity = 1.0
background-blur = false
term = xterm-256color

# 分屏分隔线颜色 (Rosé Pine)
split-divider-color = #c4a7e7


# --- 2. 分屏切换 (Cmd+hjkl -> 在 split 之间移动焦点) ---
# h=左, j=下, k=上, l=右
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:down
keybind = cmd+k=goto_split:up
keybind = cmd+l=goto_split:right
keybind = cmd+o=text:\x1bo

# --- 3. 分屏 (像 kitty 一样统一用 cmd+enter) ---
# auto: 沿较长的一边分屏 —— 宽的窗格往右分,分完变高之后再往下分
keybind = cmd+enter=new_split:auto
# 释放 cmd+shift+d (默认是往下分屏),留给别的用途
keybind = cmd+shift+d=unbind
# cmd+d 改成切换全屏 (原来 cmd+enter 干的活)
keybind = cmd+d=toggle_fullscreen




# Cursor animation
custom-shader = "~/.config/ghostty/shaders/cursor_smear.glsl"
cursor-style = block
cursor-style-blink = false
cursor-opacity = 0.5
adjust-cell-height = 20%


# macos
macos-titlebar-style = tabs
# 藏掉左上角红绿灯,但保留 tab 栏
macos-window-buttons = hidden
