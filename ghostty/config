#=================== PeterWYR's Ghostty config=====================
# Basic Config
window-padding-x = 8
window-padding-y = 8
theme = TokyoNight
font-family = "IosevkaTerm Nerd Font"
font-size = 22
font-thicken = false
macos-titlebar-style = hidden
quit-after-last-window-closed = true
background-opacity = 1.0
background-blur = false
term = "xterm-256color"

# --- 1. 窗口切换 (Cmd+1~9 -> 映射为 Alt+1~9) ---
# 先把 Ghostty 自己的 cmd+1..9（切 tab）解绑
keybind = cmd+digit_1=unbind
keybind = cmd+digit_2=unbind
keybind = cmd+digit_3=unbind
keybind = cmd+digit_4=unbind
keybind = cmd+digit_5=unbind
keybind = cmd+digit_6=unbind
keybind = cmd+digit_7=unbind
keybind = cmd+digit_8=unbind
keybind = cmd+digit_9=unbind

# 再让 cmd+1..9 发出「ESC + 数字」（也就是 M-1..9 / Alt-1..9）
keybind = cmd+digit_1=text:\x1b1
keybind = cmd+digit_2=text:\x1b2
keybind = cmd+digit_3=text:\x1b3
keybind = cmd+digit_4=text:\x1b4
keybind = cmd+digit_5=text:\x1b5
keybind = cmd+digit_6=text:\x1b6
keybind = cmd+digit_7=text:\x1b7
keybind = cmd+digit_8=text:\x1b8
keybind = cmd+digit_9=text:\x1b9

# --- 2. 分屏切换 (Cmd+hjkl -> 映射为 Alt+hjkl) ---
# h=左, j=下, k=上, l=右
keybind = cmd+h=text:\x1bh
keybind = cmd+j=text:\x1bj
keybind = cmd+k=text:\x1bk
keybind = cmd+l=text:\x1bl
keybind = cmd+o=text:\x1bo




# Cursor animation
custom-shader = "~/.config/ghostty/shaders/cursor_smear.glsl"
cursor-style = block
cursor-style-blink = false

# 将 Cmd+D 覆盖为 Tmux 的垂直分屏 (发送 Ctrl+b 然后按 %)
keybind = cmd+d=text:\x02%

# 将 Cmd+Shift+D 覆盖为 Tmux 的水平分屏 (发送 Ctrl+b 然后按 ")
keybind = cmd+shift+d=text:\x02"
