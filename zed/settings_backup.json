{
    "theme": {
        "mode": "system",
        "light": "One Light",
        "dark": "One Dark"
    },
    "agent": {
        "default_model": {
            "effort": "high",
            "provider": "zed.dev",
            "model": "claude-sonnet-4-6",
            "enable_thinking": true,
        },
        "favorite_models": [
            {
                "provider": "zed.dev",
                "model": "claude-sonnet-4-6",
                "enable_thinking": false,
            },
        ],
        "model_parameters": [],
    },
    "language_models": {
        "openai_compatible": {
            "MiniMax": {
                "api_url": "https://api.minimax.com/v1",
                "available_models": [
                    {
                        "name": "MiniMax-M2.5",
                        "max_tokens": 200000,
                        "max_output_tokens": 32000,
                        "max_completion_tokens": 200000,
                        "capabilities": {
                            "tools": false,
                            "images": false,
                            "parallel_tool_calls": false,
                            "prompt_cache_key": false,
                            "chat_completions": true,
                        },
                    },
                ],
            },
        },
    },
    "icon_theme": "Catppuccin Mocha",
    "file_finder": {
        "modal_max_width": "large",
    },
    "ui_font_family": "IosevkaTerm Nerd Font",
    "ui_font_size": 20,
    "buffer_font_family": "IosevkaTerm Nerd Font",
    "buffer_font_size": 20,
    "buffer_line_height": {
        "custom": 2,
    },
    "agent_buffer_font_size": 20,
    "vim_mode": true,
    "tab_size": 4,
    "auto_indent": false,
    "close_on_file_delete": true,
    "restore_on_file_reopen": false,
}
