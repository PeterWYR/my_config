{
    "project_panel": {
        "dock": "right"
    },
    "outline_panel": {
        "dock": "right"
    },
    "collaboration_panel": {
        "dock": "right"
    },
    "git_panel": {
        "dock": "right"
    },
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "Tokyo Night",
    },
    "agent": {
        "dock": "left",
        "default_model": {
            "effort": "medium",
            "provider": "zed.dev",
            "model": "gpt-5.4",
            "enable_thinking": true,
        },
        "favorite_models": [
            {
                "provider": "zed.dev",
                "model": "claude-sonnet-4-6",
                "enable_thinking": false,
            },
        ],
        "model_parameters": [],
    },
    "icon_theme": {
        "mode": "light",
        "light": "Bearded Icon Theme",
        "dark": "Bearded Icon Theme",
    },
    "file_finder": {
        "modal_max_width": "large",
    },
    "ui_font_family": "IosevkaTerm Nerd Font",
    "ui_font_size": 20,
    "buffer_font_family": "IosevkaTerm Nerd Font",
    "buffer_font_size": 20,
    "buffer_line_height": {
        "custom": 2,
    },
    "agent_buffer_font_size": 20,
    "vim_mode": true,
    "tab_size": 4,
    "auto_indent": "none",
    "close_on_file_delete": true,
    "restore_on_file_reopen": false,
}
